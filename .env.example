# Traders Edge MCP - all optional. The server runs fully key-less by default.

# Optional: a fully live economic calendar (tick-precise CPI/PCE/PPI release dates).
# Set ONE of these; FMP takes precedence if both are present.
# FMP_API_KEY=your_financialmodelingprep_key
# FINNHUB_API_KEY=your_finnhub_key

# Optional: annualized risk-free rate used in the Black-Scholes Greeks (default 0.043).
# TE_RISK_FREE=0.043

# Optional: verbose logging to stderr.
# DEBUG=true

# --- Tier 2: FRED (optional) ---
# FRED_API_KEY=your_fred_key        # only needed for series_search; observation tools are key-less

# --- Cross-broker aggregator (optional) ---
# ALPACA_ENV_FILE=/Users/you/Claude/mcp/alpaca/.env   # where to read Alpaca keys (default: alpaca-mcp .env)
# POSITIONS_FILE=/Users/you/.trading/positions.json   # broker-agnostic positions (default shown)
# DAILY_TARGET=524                  # daily profit target for daily_target ($)
# CONCENTRATION_PCT=25              # flag any underlying above this % of gross exposure

# --- Robinhood source (optional; auto-pulls stock + option positions) ---
# RH_USERNAME=you@example.com       # or set these in RH_ENV_FILE
# RH_PASSWORD=...
# RH_ENV_FILE=/Users/you/Claude/MCP/robin-hood/.env   # default: robinhood-local .env
# RH_PICKLE_PATH=~/.robinhood       # cached robin_stocks session dir (default shown)

# --- Robinhood-native tools (v0.9.0; all optional) ---
# RH_PNL_HUB_URL=                    # official realized-P&L "PnL hub" endpoint for realized_pnl (URL
#                                    # template; may contain {span} and {account}). Undocumented - capture
#                                    # from the app's Realized-P&L page in browser devtools. If unset,
#                                    # realized_pnl uses its fee-inclusive round-trip figure as authoritative.
# RH_INDEX_QUOTE_URL=                # pin the Robinhood index-quote endpoint used by index_quote / spot_blend
#                                    # ({ids} = comma-joined instrument UUIDs). If unset, candidate endpoints
#                                    # are probed and the first working one is cached.
# RH_SPX_ID=432fbbb8-b82c-454a-852d-eb85382c7066   # index instrument-ID overrides (defaults shown)
# RH_VIX_ID=3b912aa2-88f9-4682-8ae3-e39520bdf4db
# RH_NDX_ID=50c298f7-27a8-44a1-b049-ec153cf2892f

# --- E*TRADE source (optional; auto-pulls stock + option positions) ---
# ETRADE_CONSUMER_KEY=...            # or set these in ET_ENV_FILE
# ETRADE_CONSUMER_SECRET=...
# ET_ENV_FILE=/Users/you/Claude/MCP/Etrade-MCP/.env    # default: etrade MCP .env
# ET_TOKEN_FILE=~/.etrade/tokens.pickle   # cached pyetrade OAuth session (default shown)
# ETRADE_SANDBOX=false

# --- Beta map for SPX-weighting auto-pulled equities (optional) ---
# BETA_OVERRIDES=ICE:1.05,NVDA:1.7   # inline per-symbol beta overrides
# BETA_MAP_FILE=/path/to/betas.json  # or a JSON {"SYMBOL": beta} file

# --- Discipline layer tunables (optional) ---
# TE_GIVEBACK_FRAC=0.40        # give-back from intraday peak (x target) that triggers STOP
# TE_RAPID_REENTRY_SECS=90     # entries closer together than this flag churning
# TE_LATE_SESSION_ET=15:45     # final-stretch CAUTION after this ET time

# --- User config file & snapshot DB (optional) ---
# TE_CONFIG_FILE=/Users/you/Claude/mcp/traders-edge-mcp/config.json  # goals/discipline knobs (default: next to server)
# TE_DB_PATH=~/.trading/traders_edge.db   # SQLite snapshot log for snapshot_log/history (default shown)
