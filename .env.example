# Traders Edge MCP - all optional. The server runs fully key-less by default.

# Optional: a fully live economic calendar (tick-precise CPI/PCE/PPI release dates).
# Set ONE of these; FMP takes precedence if both are present.
# FMP_API_KEY=your_financialmodelingprep_key
# FINNHUB_API_KEY=your_finnhub_key

# Optional: annualized risk-free rate used in the Black-Scholes Greeks (default 0.043).
# TE_RISK_FREE=0.043

# Optional: verbose logging to stderr.
# DEBUG=true

# --- Tier 2: FRED (optional) ---
# FRED_API_KEY=your_fred_key        # only needed for series_search; observation tools are key-less

# --- Cross-broker aggregator (optional) ---
# ALPACA_ENV_FILE=/Users/you/Claude/mcp/alpaca/.env   # where to read Alpaca keys (default: alpaca-mcp .env)
# POSITIONS_FILE=/Users/you/.trading/positions.json   # broker-agnostic positions (default shown)
# DAILY_TARGET=524                  # daily profit target for daily_target ($)
# CONCENTRATION_PCT=25              # flag any underlying above this % of gross exposure
